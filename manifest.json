{
  "manifest_version": 3,
  "name": "SubStream — Subtitles Overlay",
  "short_name": "SubStream",
  "version": "1.1.0",
  "description": "Add subtitles in any language to any streaming platform. Search SubDL, load local SRT files or whole season folders, auto-advance between episodes, and fine-tune timing with one click.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "https://api.subdl.com/*",
    "https://dl.subdl.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://github.com/substream-ext/substream"
}
